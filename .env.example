# ─────────────────────────────────────────────
# KP Infra — Environment Variables
# Copy this file to .env.local for local dev
# Set these in Vercel → Project → Settings → Environment Variables
# ─────────────────────────────────────────────

# MongoDB Atlas connection string (REQUIRED for API routes)
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_URL=mongodb+srv://your_user:your_password@cluster.mongodb.net/?retryWrites=true&w=majority

# Optional: override the default database name (default: kp_infra)
DB_NAME=kp_infra

# Optional: restrict CORS origins (default: *)
# Example: CORS_ORIGINS=https://your-vercel-domain.vercel.app
CORS_ORIGINS=*
